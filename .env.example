NEXT_PUBLIC_R2_PUBLIC_URL=your_r2_public_url_here

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal testing
# Comma-separated emails allowed to access /admin (leave empty for all users)
ADMIN_EMAILS=you@example.com
